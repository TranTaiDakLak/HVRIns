# ── Build output ─────────────────────────────────────────
build/bin/*
# Track TOÀN BỘ build/bin/Config (data pool tĩnh + runtime: Cookie, Proxy,
# RentMail, Settings...) — user tự quản lý data này.
# ⚠ Repo phải PRIVATE: Config chứa cookie session sống + proxy/mail creds + API keys.
!build/bin/Config/
/bin/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.zip

# Delve debug binary (generated by VS Code Go debugger)
__debug_bin*

# ── Go ───────────────────────────────────────────────────
vendor/
*.test
*.out
go.work
go.work.sum

# ── Node / Frontend ──────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/package.json.md5
*.local

# ── Wails generated bindings ─────────────────────────────
# Các file này do `wails build` / `wails generate` tự sinh ra từ Go code.
# Bình thường sẽ thấy chúng thay đổi sau mỗi lần thêm method Go mới — đó là bình thường.
#
# Quyết định: COMMIT lại vào repo để người clone không cần
# cài Go + chạy `wails generate` mới dùng được TypeScript types.
#
# Nếu muốn IGNORE hoàn toàn (tự generate khi build), bỏ comment dòng dưới:
# frontend/wailsjs/

# ── Database ─────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# ── VS Code ───────────────────────────────────────────────
# Commit: launch.json, tasks.json (shared debug config)
# Ignore: settings.json (có path máy cụ thể)
.vscode/settings.json
.vscode/*.code-workspace

# ── IDE khác ─────────────────────────────────────────────
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── OS ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
desktop.ini

# ── Runtime config & secrets ─────────────────────────────
Config/Settings/
Config/Secrets/
!Config/Settings/.gitkeep
!Config/Secrets/.gitkeep

# ── Env / Secrets ────────────────────────────────────────
.env
.env.*
!.env.example

# ── Runtime output ───────────────────────────────────────
result/

# ── Logs ─────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Test / Coverage ──────────────────────────────────────
coverage/
*.coverprofile

# ── Temp / Tools ─────────────────────────────────────────
.gstack/
tmp/
.tmp/
.claude/
build/bin/Config/RentMail/unused_zeus-x.txt
build/bin/Config/RentMail/used_zeus-x.txt
build/bin/Config/RentMail/bought_zeus-x.txt

# Runtime data — không commit (cookie session, mail/phone creds, settings máy)
/build/bin/Config/Cookie/
/build/bin/Config/Permanent/
/build/bin/Config/Settings/
build/bin/Config/Settings/app_settings.json
build/bin/Config/Settings/interaction.json
frontend/wailsjs/runtime/runtime.d.ts
frontend/wailsjs/runtime/runtime.js
/build/bin/Config/Settings

# ── Messenger reg/ver debug dumps (test artifacts ở root — KHÔNG commit) ──
/am_*.json
/amreq_*.txt
/bottomsheet_*.json
/change_email_*.json
/createreq_*.txt
/createresp_*.json
/tmp_diff/

# ── Secrets / runtime data (KHÔNG commit) ──
# Các thư mục runtime mà app tạo ra tại chỗ — config/sample/ (tracked) không bị ảnh hưởng
Config/Cookie/
Config/Proxy/
Config/TempMail/
Config/Permanent/
Config/DeviceInfo/
test_accounts*.txt

# ── Python build cache ──
__pycache__/
*.pyc
