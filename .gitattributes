# Normalize line endings: repo lưu LF, Windows checkout tự convert
* text=auto

# Go — luôn LF
*.go text eol=lf
go.mod text eol=lf
go.sum text eol=lf

# Frontend
*.ts text eol=lf
*.vue text eol=lf
*.js text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf

# Binary — không touch line endings
*.exe binary
*.dll binary
*.ico binary
*.png binary
*.jpg binary
*.svg text eol=lf
